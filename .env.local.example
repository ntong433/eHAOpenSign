NODE_ENV=development
APP_ID=opensign
PUBLIC_URL=http://localhost:3000
SERVER_URL=http://localhost:8085/app
REACT_APP_SERVERURL=http://localhost:8085/app
PARSE_MOUNT=/app
MONGODB_URI=mongodb://mongo:27017/OpenSignDB
DATABASE_URI=mongodb://mongo:27017/OpenSignDB
USE_LOCAL=true

# Supply a non-production development master key outside source control.
MASTER_KEY=

# Optional Microsoft Entra/Graph settings. Password login remains enabled when
# these are set; never commit the secret values.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
MICROSOFT_REDIRECT_URI=http://localhost:3000/auth/microsoft/callback
GRAPH_DEFAULT_SENDER=helpdesk@lhinigeria.org
GRAPH_SERVICE_ACCOUNT=helpdesk@lhinigeria.org
