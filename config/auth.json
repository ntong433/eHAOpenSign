{
  "defaultProvider": "localAdministrator",
  "providers": {
    "localAdministrator": {
      "enabled": true,
      "allowPasswordLogin": true
    },
    "microsoftEntraId": {
      "enabled": true,
      "tenantIdEnv": "MICROSOFT_ENTRA_TENANT_ID",
      "clientIdEnv": "MICROSOFT_ENTRA_CLIENT_ID",
      "clientSecretEnv": "MICROSOFT_ENTRA_CLIENT_SECRET",
      "redirectUriEnv": "MICROSOFT_ENTRA_REDIRECT_URI",
      "scopes": [
        "openid",
        "profile",
        "email",
        "User.Read"
      ],
      "graphSyncFields": [
        "displayName",
        "mail",
        "userPrincipalName",
        "jobTitle",
        "department",
        "officeLocation",
        "manager",
        "employeeId",
        "mobilePhone",
        "businessPhones",
        "companyName"
      ],
      "autoProvision": true,
      "syncOnLogin": true
    }
  }
}
